# Copy to .env and fill in
VITE_WALLETCONNECT_PROJECT_ID=get_from_walletconnect_cloud
VITE_ARWEAVE_KEY=your_arweave_jwk_key_as_json_string

# Arweave Deployment (filled in after running npm run deploy:arweave)
VITE_ARWEAVE_APP_TX=your_app_manifest_tx_id_here
VITE_ARWEAVE_RECOVERY_TX=your_recovery_guide_tx_id_here

# Contract addresses (optional — auto-filled by deploy script)
VITE_POST_REGISTRY=0x...
VITE_VAULT_REGISTRY=0x...
VITE_USER_REGISTRY=0x...
VITE_POINTS_SYSTEM=0x...
